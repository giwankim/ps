#!/usr/bin/env bash
set -euo pipefail

STAGED=$(git diff --cached --name-only --diff-filter=d)

if [ -z "$STAGED" ]; then
  echo "No staged files."
  exit 0
fi

if ! grep -qE '\.(java|kts?)$' <<<"$STAGED"; then
  echo "No staged Java/Kotlin files. Skipping checks."
  exit 0
fi

# Hide unstaged tracked changes while checks run against the index.
STASH_NAME="pre-commit-$(date +%s)"
git stash push -q --keep-index -m "$STASH_NAME"
STASHED=true

restore_stash() {
  if [ "$STASHED" = true ]; then
    git stash pop -q
    STASHED=false
  fi
}
trap restore_stash EXIT

echo "Running spotless check..."
./gradlew spotlessCheck

echo "Running ktlint check..."
./gradlew ktlintCheck
